{
    "$schema": "https://tr.designtokens.org/format/",
    "$metadata": {
        "description": "artpqUX 디자인 토큰 — 단일 소스. 직접 수정 후 node scripts/build-tokens.js 실행.",
        "remBase": 10,
        "remNote": "html { font-size: 62.5% } → 1rem = 10px. px→rem: px / 10"
    },
    "color": {
        "$type": "color",
        "$description": "Bootstrap 기본값 참조. 변경 시 scss/1-settings/_vendor.scss의 Sass 변수도 동일 수정.",
        "primary":    { "$value": "#0d6efd", "$type": "color" },
        "secondary":  { "$value": "#6c757d", "$type": "color" },
        "text":       { "$value": "#212529", "$type": "color" },
        "text-muted": { "$value": "#6c757d", "$type": "color" },
        "bg":         { "$value": "#fff",    "$type": "color" },
        "border":     { "$value": "#dee2e6", "$type": "color" },
        "error":      { "$value": "#dc3545", "$type": "color" },
        "success":    { "$value": "#198754", "$type": "color" }
    },
    "font-size": {
        "$type": "dimension",
        "$description": "[62.5% REM] 1rem = 10px",
        "xs":   { "$value": "1.1rem", "$type": "dimension", "$px": 11 },
        "sm":   { "$value": "1.3rem", "$type": "dimension", "$px": 13 },
        "base": { "$value": "1.6rem", "$type": "dimension", "$px": 16, "$note": "Bootstrap $font-size-base 대응" },
        "md":   { "$value": "1.9rem", "$type": "dimension", "$px": 19 },
        "lg":   { "$value": "2.2rem", "$type": "dimension", "$px": 22 },
        "xl":   { "$value": "2.8rem", "$type": "dimension", "$px": 28 },
        "2xl":  { "$value": "3.6rem", "$type": "dimension", "$px": 36 }
    },
    "font-weight": {
        "$type": "fontWeight",
        "regular": { "$value": 400, "$type": "fontWeight" },
        "medium":  { "$value": 500, "$type": "fontWeight" },
        "bold":    { "$value": 700, "$type": "fontWeight" }
    },
    "leading": {
        "$type": "number",
        "tight":  { "$value": 1.25, "$type": "number" },
        "normal": { "$value": 1.5,  "$type": "number", "$note": "Bootstrap $line-height-base 기본값" },
        "loose":  { "$value": 1.75, "$type": "number" }
    },
    "accessibility": {
        "$type": "dimension",
        "touch-target-min": { "$value": "4.4rem", "$type": "dimension", "$px": 44, "$note": "WCAG 2.5.8 최소 터치영역" }
    },
    "spacing": {
        "$type": "dimension",
        "$description": "4px 기반 7단계. [62.5% REM] 4px = 0.4rem",
        "xs":  { "$value": "0.4rem", "$type": "dimension", "$px": 4  },
        "sm":  { "$value": "0.8rem", "$type": "dimension", "$px": 8  },
        "md":  { "$value": "2.0rem", "$type": "dimension", "$px": 20 },
        "lg":  { "$value": "2.8rem", "$type": "dimension", "$px": 28 },
        "xl":  { "$value": "3.2rem", "$type": "dimension", "$px": 32 },
        "2xl": { "$value": "4.8rem", "$type": "dimension", "$px": 48 },
        "3xl": { "$value": "6.4rem", "$type": "dimension", "$px": 64 }
    },
    "shadow": {
        "$type": "shadow",
        "$description": "Bootstrap --bs-box-shadow-* 값 참조",
        "sm": { "$value": "0 0.125rem 0.25rem rgba(0, 0, 0, 0.075)", "$type": "shadow" },
        "md": { "$value": "0 0.5rem 1rem rgba(0, 0, 0, 0.15)",       "$type": "shadow" },
        "lg": { "$value": "0 1rem 3rem rgba(0, 0, 0, 0.175)",        "$type": "shadow" }
    },
    "transition": {
        "$type": "duration",
        "fast": { "$value": "150ms ease", "$type": "duration" },
        "base": { "$value": "300ms ease", "$type": "duration" }
    },
    "z": {
        "$type": "number",
        "$description": "Bootstrap z-index 체계와 정렬",
        "dropdown": { "$value": 1000, "$type": "number" },
        "overlay":  { "$value": 1040, "$type": "number" },
        "modal":    { "$value": 1050, "$type": "number" }
    }
}
